# =============================================================================
# OCR Document Scanner — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# See also: backend/.env.example  and  frontend/.env.example
#
# NEVER commit .env files with real secrets to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
FLASK_ENV=development            # development | production | testing
DEBUG=false
SECRET_KEY=change-me-in-production-use-python-c-import-secrets-print-secrets-token-urlsafe-64
JWT_SECRET_KEY=change-me-separate-from-secret-key
JWT_ACCESS_TOKEN_EXPIRES=86400   # seconds (24 h)
JWT_REFRESH_TOKEN_EXPIRES=2592000 # seconds (30 d)

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for dev, PostgreSQL for production
DATABASE_URL=sqlite:///ocr_scanner.db
# DATABASE_URL=postgresql://user:password@localhost:5432/ocr_scanner
POSTGRES_DB=ocr_scanner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ── Redis (optional — enables caching + Celery) ─────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=change-me

# ── Security ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MAX_CONTENT_LENGTH=16777216      # 16 MB
UPLOAD_FOLDER=uploads
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60             # seconds

# ── OCR ──────────────────────────────────────────────────────────────────────
OCR_TIMEOUT=60
OCR_DPI=300
OCR_LANGUAGES=eng,ara,hin
TESSERACT_CMD=/usr/bin/tesseract

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=app.log

# ── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ── Flower (Celery monitor) ─────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change-me

# ── Vision AI (optional — enables Claude Vision pipeline) ────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
VISION_MODEL=claude-sonnet-4-20250514
VISION_ENABLED=true

# ── WebSocket ────────────────────────────────────────────────────────────────
ENABLE_WEBSOCKET=true

# ── Production-only (uncomment for production) ───────────────────────────────
# WORKERS=4
# WORKER_CLASS=gevent
# WORKER_TIMEOUT=120
# SSL_CERT_PATH=/etc/ssl/certs/server.crt
# SSL_KEY_PATH=/etc/ssl/private/server.key
# FORCE_HTTPS=true
# SENTRY_DSN=https://...@sentry.io/...
