# Production Environment Variables
FLASK_ENV=production
FLASK_DEBUG=False
TESSERACT_CMD=/usr/bin/tesseract

# Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=/app/uploads

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ocr_scanner
POSTGRES_DB=ocr_scanner  
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=change-this-password

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OCR Configuration  
OCR_TIMEOUT=60
OCR_DPI=300
OCR_LANGUAGES=eng,ara,hin,spa,fra,deu,jpn,kor

# Security (generate secure keys for production)
SECRET_KEY=your-secret-key-here

# CORS Configuration
CORS_ORIGINS=*

# File Management
FILE_CLEANUP_DAYS=7
MAX_FILE_SIZE=16777216

# Monitoring
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-password

# API Configuration
RATE_LIMIT_PER_MINUTE=60
CONFIDENCE_THRESHOLD=0.6

# Security
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,tiff,bmp
MAX_BATCH_SIZE=50

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
