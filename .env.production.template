# OCR Document Scanner - Production Environment Configuration
# This is a template file. Copy to .env.production and configure with actual values
# NEVER commit the actual .env.production file to version control

# ================================
# CRITICAL SECURITY - MUST CHANGE
# ================================

# Generate using: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=${SECRET_KEY}
JWT_SECRET_KEY=${JWT_SECRET_KEY}

# Database credentials - use strong passwords
DATABASE_URL=${DATABASE_URL}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
REDIS_PASSWORD=${REDIS_PASSWORD}

# ================================
# APPLICATION CONFIGURATION
# ================================

FLASK_ENV=production
DEBUG=false
FLASK_DEBUG=false

# JWT Configuration (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600  # 1 hour
JWT_REFRESH_TOKEN_EXPIRES=86400  # 24 hours

# ================================
# SECURITY CONFIGURATION
# ================================

# CORS - Set to your actual domain
CORS_ORIGINS=https://yourdomain.com

# File Upload Limits (16MB default)
MAX_CONTENT_LENGTH=16777216
MAX_FILE_SIZE=16777216
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,tiff,bmp
UPLOAD_FOLDER=/var/app/uploads

# Virus Scanning
ENABLE_VIRUS_SCAN=true
CLAMAV_SOCKET=/var/run/clamav/clamd.ctl

# Rate Limiting (Redis-based)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/1
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Security Headers
SECURITY_HEADERS_ENABLED=true
CONTENT_SECURITY_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';"

# ================================
# DATABASE CONFIGURATION
# ================================

# PostgreSQL for production
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:5432/${DB_NAME}
DATABASE_POOL_SIZE=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_MAX_OVERFLOW=40

# ================================
# REDIS CONFIGURATION
# ================================

REDIS_URL=redis://:{REDIS_PASSWORD}@${REDIS_HOST}:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_CONNECTION_TIMEOUT=5

# ================================
# SSL/HTTPS CONFIGURATION
# ================================

FORCE_HTTPS=true
SSL_CERT_PATH=/etc/ssl/certs/server.crt
SSL_KEY_PATH=/etc/ssl/private/server.key
SSL_DISABLE=false
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ================================
# LOGGING CONFIGURATION
# ================================

LOG_LEVEL=WARNING
LOG_FILE=/var/log/ocr-scanner/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5
SENTRY_DSN=${SENTRY_DSN}  # For error tracking

# ================================
# MONITORING
# ================================

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# ================================
# WORKER CONFIGURATION
# ================================

WORKERS=4
WORKER_CLASS=gevent
WORKER_TIMEOUT=120
WORKER_CONNECTIONS=1000
THREADS_PER_WORKER=2

# ================================
# CELERY CONFIGURATION
# ================================

CELERY_BROKER_URL=redis://:{REDIS_PASSWORD}@${REDIS_HOST}:6379/2
CELERY_RESULT_BACKEND=redis://:{REDIS_PASSWORD}@${REDIS_HOST}:6379/3
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# ================================
# CLAUDE VISION (AI Document Analysis)
# ================================

ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
VISION_MODEL=claude-sonnet-4-20250514
VISION_ENABLED=true

# ================================
# CLOUD STORAGE (Optional)
# ================================

# AWS S3
USE_S3=false
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_REGION=us-east-1
AWS_S3_BUCKET=${AWS_S3_BUCKET}

# ================================
# BACKUP CONFIGURATION
# ================================

BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 3 * * *"  # 3 AM daily
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=${BACKUP_S3_BUCKET}

# ================================
# DEPLOYMENT VALIDATION
# ================================

VALIDATE_ENV_ON_STARTUP=true
REQUIRED_ENV_VARS=SECRET_KEY,JWT_SECRET_KEY,DATABASE_URL,REDIS_URL,CORS_ORIGINS