# OCR Document Scanner - Environment Configuration Template
# Copy this file to .env and configure the values for your deployment

# ================================
# APPLICATION CONFIGURATION
# ================================

# Flask Environment (development/production)
FLASK_ENV=development

# Secret Keys (MUST BE CHANGED IN PRODUCTION)
# Generate secure keys using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-different-from-secret-key

# JWT Token Expiration (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=86400
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ================================
# SECURITY CONFIGURATION
# ================================

# CORS Origins (comma-separated, use * for development only)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ================================
# DATABASE CONFIGURATION
# ================================

# Database URL (SQLite for development, PostgreSQL for production)
# Development: sqlite:///ocr_scanner.db
# Production: postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///ocr_scanner.db

# PostgreSQL specific (for production)
POSTGRES_DB=ocr_scanner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password_here

# ================================
# REDIS CONFIGURATION
# ================================

# Redis URL for caching and task queues
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=secure_redis_password

# ================================
# OCR CONFIGURATION
# ================================

# OCR Processing Configuration
OCR_TIMEOUT=60
OCR_DPI=300
OCR_LANGUAGES=eng,ara,hin,deu,fra,spa,rus,chi_sim,jpn,kor

# Tesseract Path (usually auto-detected)
TESSERACT_CMD=/usr/bin/tesseract

# ================================
# CELERY CONFIGURATION
# ================================

# Celery Broker and Result Backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ================================
# MONITORING & LOGGING
# ================================

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Prometheus Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ================================
# FLOWER MONITORING
# ================================

# Flower Web Interface Credentials
FLOWER_USER=admin
FLOWER_PASSWORD=secure_flower_password

# ================================
# PRODUCTION DEPLOYMENT
# ================================

# Server Configuration
WORKERS=2
WORKER_CLASS=sync
WORKER_TIMEOUT=120
WORKER_CONNECTIONS=1000

# SSL Configuration (for production)
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# ================================
# CLOUD DEPLOYMENT
# ================================

# AWS Configuration (if using AWS)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-ocr-bucket

# Google Cloud Configuration (if using GCP)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your-project-id

# ================================
# DEVELOPMENT SETTINGS
# ================================

# Debug Mode (DO NOT ENABLE IN PRODUCTION)
DEBUG=false

# Flask Debug Mode
FLASK_DEBUG=false

# Development Database
DEV_DATABASE_URL=sqlite:///dev_ocr_scanner.db

# ================================
# TESTING CONFIGURATION
# ================================

# Test Database
TEST_DATABASE_URL=sqlite:///test_ocr_scanner.db

# Test API Key
TEST_API_KEY=test_api_key_for_development

# ================================
# SECURITY NOTES
# ================================

# IMPORTANT SECURITY CHECKLIST:
# 1. Change all default passwords and secret keys
# 2. Use strong, unique passwords for database and Redis
# 3. Enable HTTPS in production
# 4. Restrict CORS origins to your domain
# 5. Use environment-specific configuration
# 6. Enable rate limiting
# 7. Use proper database permissions
# 8. Enable audit logging
# 9. Regular security updates
# 10. Monitor for security events

# ================================
# DEPLOYMENT VALIDATION
# ================================

# Set to true to validate environment on startup
VALIDATE_ENV_ON_STARTUP=true

# Required environment variables for production
REQUIRED_PROD_VARS=SECRET_KEY,JWT_SECRET_KEY,DATABASE_URL,REDIS_URL