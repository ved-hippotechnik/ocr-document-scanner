# =============================================================================
# OCR Document Scanner — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# Required
SECRET_KEY=change-me-in-production-min-32-chars
JWT_SECRET_KEY=change-me-separate-from-secret-key

# Database (SQLite for dev, PostgreSQL for prod)
# DATABASE_URL=postgresql://user:pass@localhost:5432/ocr_scanner

# Vision AI (optional — enables Claude Vision hybrid pipeline)
ANTHROPIC_API_KEY=
VISION_MODEL=claude-sonnet-4-20250514
VISION_ENABLED=true

# Redis (optional — enables caching and Celery async processing)
# REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# OCR
OCR_TIMEOUT=60
OCR_DPI=300
OCR_LANGUAGES=eng,ara,hin

# File Uploads
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# WebSocket
ENABLE_WEBSOCKET=true
